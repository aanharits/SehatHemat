generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model ingridients {
  id       BigInt  @id
  name     String?
  category String?
  price    BigInt?
  protein  Float?
  calories BigInt?
  unit     String?
}

model SavedMealPlan {
  id             String   @id @default(cuid())
  dayName        String
  meals          Json     // { breakfast: { menu, price }, lunch: { menu, price }, dinner: { menu, price } }
  totalProtein   Float
  totalCalories  Float
  dailyCost      Float
  createdAt      DateTime @default(now())

  @@map("saved_meal_plans")
}
