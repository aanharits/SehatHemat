generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model ingridients {
  id       BigInt  @id
  name     String?
  category String?
  price    BigInt?
  protein  Float?
  calories BigInt?
  unit     String?
}

model User {
  id          String   @id @db.Uuid
  email       String   @unique
  displayName String?
  avatarUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  savedMealPlans SavedMealPlan[]
  activeMealPlan ActiveMealPlan?

  @@map("users")
}

model ActiveMealPlan {
  id             String   @id @default(cuid())
  userId         String   @unique @db.Uuid
  weeklyPlan     Json
  budget         Float
  targetCalories Float
  targetProtein  Float
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("active_meal_plans")
}

model SavedMealPlan {
  id            String   @id @default(cuid())
  userId        String   @db.Uuid
  dayName       String
  meals         Json
  totalProtein  Float
  totalCalories Float
  dailyCost     Float
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("saved_meal_plans")
}
